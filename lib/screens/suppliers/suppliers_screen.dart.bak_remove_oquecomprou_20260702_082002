class _PurchasesBoard extends StatelessWidget {
  const _PurchasesBoard({
    required this.purchases,
    required this.fillHeight,
    required this.onEdit,
    required this.onDelete,
    required this.onTogglePaid,
  });

  final List<SupplierPurchase> purchases;
  final bool fillHeight;
  final ValueChanged<SupplierPurchase> onEdit;
  final ValueChanged<SupplierPurchase> onDelete;
  final ValueChanged<SupplierPurchase> onTogglePaid;

  @override
  Widget build(BuildContext context) {
    final list = purchases.isEmpty
        ? const _EmptySuppliers()
        : ListView.separated(
            shrinkWrap: !fillHeight,
            physics: fillHeight
                ? null
                : const NeverScrollableScrollPhysics(),
            itemCount: purchases.length,
            separatorBuilder: (_, __) => const SizedBox(height: 12),
            itemBuilder: (context, index) {
              final purchase = purchases[index];

              return _PurchaseCard(
                purchase: purchase,
                onEdit: () => onEdit(purchase),
                onDelete: () => onDelete(purchase),
                onTogglePaid: () => onTogglePaid(purchase),
              );
            },
          );

    return _LightPanel(
      padding: const EdgeInsets.all(16),
      child: fillHeight
          ? Column(
              children: [
                _BoardHeader(count: purchases.length),
                const SizedBox(height: 14),
                Expanded(child: list),
              ],
            )
          : Column(
              children: [
                _BoardHeader(count: purchases.length),
                const SizedBox(height: 14),
                list,
              ],
            ),
    );
  }
}

