          title: 'Resumo de compras',
          subtitle: 'Gasto total e pendências',
          icon: Icons.analytics_rounded,
          children: [
            _DarkSummaryNumber(
              label: 'Total comprado',
              value: _formatMoney(totalPurchased),
            ),
            const SizedBox(height: 10),
            _DarkSummaryNumber(
              label: 'Em aberto',
              value: _formatMoney(openAmount),
            ),
          ],
        ),
        const SizedBox(height: 14),
        _SupplierDirectoryPanel(
          suppliers: supplierProfiles,
          purchases: provider.purchases,
          onAdd: () => _openSupplierDialog(context),
          onEdit: (supplier) => _openSupplierDialog(
            context,
            supplier: supplier,
          ),
          onToggleActive: (supplier) {
            context.read<SuppliersProvider>().toggleSupplierActive(supplier.id);
