class _SupplierStats {
  const _SupplierStats({
    required this.total,
    required this.open,
    required this.lastPurchase,
  });

  final double total;
  final double open;
  final DateTime? lastPurchase;
}

_SupplierStats _supplierStats(
  String supplierName,
  List<SupplierPurchase> purchases,
) {
  final normalized = supplierName.trim().toLowerCase();

  final supplierPurchases = purchases.where((purchase) {
    return purchase.supplierName.trim().toLowerCase() == normalized;
  }).toList();

  supplierPurchases.sort((a, b) => b.purchaseDate.compareTo(a.purchaseDate));

  final total = supplierPurchases.fold<double>(
    0,
    (sum, purchase) => sum + purchase.totalCost,
  );

  final open = supplierPurchases.where((purchase) => !purchase.paid).fold<double>(
        0,
        (sum, purchase) => sum + purchase.totalCost,
      );

  return _SupplierStats(
    total: total,
    open: open,
    lastPurchase:
        supplierPurchases.isEmpty ? null : supplierPurchases.first.purchaseDate,
  );
}

