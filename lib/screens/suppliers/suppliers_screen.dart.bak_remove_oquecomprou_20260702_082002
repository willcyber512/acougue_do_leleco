  void _save() {
    final name = nameController.text.trim();

    if (name.isEmpty) {
      ScaffoldMessenger.of(context)
        ..clearSnackBars()
        ..showSnackBar(
          const SnackBar(content: Text('Informe o nome do fornecedor.')),
        );
      return;
    }

    final provider = context.read<SuppliersProvider>();
    final now = DateTime.now();
    final old = widget.supplier;

    final supplier = SupplierProfile(
      id: old?.id ?? const Uuid().v4(),
      name: name,
      phone: phoneController.text.trim(),
      responsible: responsibleController.text.trim(),
      city: cityController.text.trim(),
      address: addressController.text.trim(),
      notes: notesController.text.trim(),
      active: active,
      createdAt: old?.createdAt ?? now,
      updatedAt: now,
    );

    if (old == null) {
      provider.addSupplier(supplier);
    } else {
      provider.updateSupplier(supplier);
    }

    Navigator.of(context).pop();

    ScaffoldMessenger.of(context)
      ..clearSnackBars()
      ..showSnackBar(
        const SnackBar(content: Text('Fornecedor salvo.')),
      );
  }
}

