enum _TodaySection {
  summary,
  shortcuts,
  sales,
  cash,
  lowStock,
  suppliersOpen,
  fiado,
  losses,
}

extension _TodaySectionInfo on _TodaySection {
  String get label {
    switch (this) {
      case _TodaySection.summary:
        return 'Resumo rápido';
      case _TodaySection.shortcuts:
        return 'Atalhos rápidos';
      case _TodaySection.sales:
        return 'Vendas de hoje';
      case _TodaySection.cash:
        return 'Caixa do dia';
      case _TodaySection.lowStock:
        return 'Estoque baixo';
      case _TodaySection.suppliersOpen:
        return 'Fornecedores em aberto';
      case _TodaySection.fiado:
        return 'Fiado de hoje';
      case _TodaySection.losses:
        return 'Perdas recentes';
    }
  }

  String get subtitle {
    switch (this) {
      case _TodaySection.summary:
        return 'Cards principais do dia';
      case _TodaySection.shortcuts:
        return 'Botões para abrir módulos';
      case _TodaySection.sales:
        return 'Faturamento e quantidade de vendas';
      case _TodaySection.cash:
        return 'Dinheiro, pix, cartão e fiado';
      case _TodaySection.lowStock:
        return 'Produtos que precisam de atenção';
      case _TodaySection.suppliersOpen:
        return 'Compras pendentes de pagamento';
      case _TodaySection.fiado:
        return 'Vendas fiadas registradas hoje';
      case _TodaySection.losses:
        return 'Últimas perdas do estoque';
    }
  }

  IconData get icon {
    switch (this) {
      case _TodaySection.summary:
        return Icons.dashboard_customize_rounded;
      case _TodaySection.shortcuts:
        return Icons.bolt_rounded;
      case _TodaySection.sales:
        return Icons.receipt_long_rounded;
      case _TodaySection.cash:
        return Icons.payments_rounded;
      case _TodaySection.lowStock:
        return Icons.warning_rounded;
      case _TodaySection.suppliersOpen:
        return Icons.local_shipping_rounded;
      case _TodaySection.fiado:
        return Icons.people_alt_rounded;
      case _TodaySection.losses:
        return Icons.remove_circle_rounded;
    }
  }
}

class HomeDashboardScreen extends StatefulWidget {
  const HomeDashboardScreen({super.key, required this.onNavigate});

  final ValueChanged<int> onNavigate;

  @override
  State<HomeDashboardScreen> createState() => _HomeDashboardScreenState();
}

class _HomeDashboardScreenState extends State<HomeDashboardScreen> {
  static const String _storageKey = 'leleco_today_sections_v1';

  final Map<_TodaySection, bool> visibleSections = {
    for (final section in _TodaySection.values) section: true,
  };

  bool loaded = false;

  @override
  void initState() {
    super.initState();
    _loadPreferences();
  }

  @override
  Widget build(BuildContext context) {
    final sales = context.watch<SalesProvider>();
    final inventory = context.watch<InventoryProvider>();
    final suppliers = context.watch<SuppliersProvider>();
    final shortcuts = context.watch<ShortcutsProvider>();

    final todaySales = sales.todaySales
        .where((sale) => !sale.isCanceled)
        .toList();

    final todayRevenue = todaySales.fold<double>(
      0,
      (total, sale) => total + sale.total,
    );

    final todayFiadoSales = todaySales
        .where((sale) => sale.paymentMethod == PaymentMethod.fiado)
        .toList();

    final todayFiadoTotal = todayFiadoSales.fold<double>(
      0,
      (total, sale) => total + sale.total,
    );

    final lowStockProducts =
        inventory.products.where((product) => product.isLowStock).toList()
          ..sort((a, b) => a.stockQuantity.compareTo(b.stockQuantity));

    final openSupplierPurchases = suppliers.purchases
        .where((purchase) => !purchase.paid)
        .toList();

    final openSupplierAmount = openSupplierPurchases.fold<double>(
      0,
      (total, purchase) => total + purchase.totalCost,
    );

    final todayLosses = inventory.losses
        .where((loss) => _isToday(loss.createdAt))
        .toList();

    final recentLosses = inventory.losses.take(5).toList();

    return SingleChildScrollView(
      padding: const EdgeInsets.only(bottom: 24),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          _TodayHero(
            todayRevenue: todayRevenue,
            salesCount: todaySales.length,
            alertsCount: lowStockProducts.length + openSupplierPurchases.length,
            onCustomize: _openCustomizeDialog,
            onNavigate: widget.onNavigate,
          ),
          const SizedBox(height: 16),
          if (_isVisible(_TodaySection.summary))
            _SummaryGrid(
              cards: [
                _SummaryCardData(
                  icon: Icons.payments_rounded,
                  title: 'Faturamento hoje',
                  value: _formatMoney(todayRevenue),
                  subtitle: '${todaySales.length} venda(s)',
                  onTap: () => widget.onNavigate(4),
                ),
                _SummaryCardData(
                  icon: Icons.warning_rounded,
                  title: 'Estoque baixo',
                  value: lowStockProducts.length.toString(),
                  subtitle: 'produto(s) com atenção',
                  onTap: () => widget.onNavigate(2),
                ),
                _SummaryCardData(
                  icon: Icons.local_shipping_rounded,
                  title: 'A pagar fornecedores',
                  value: _formatMoney(openSupplierAmount),
                  subtitle: '${openSupplierPurchases.length} compra(s)',
                  onTap: () => widget.onNavigate(6),
                ),
                _SummaryCardData(
                  icon: Icons.people_alt_rounded,
                  title: 'Fiado hoje',
                  value: _formatMoney(todayFiadoTotal),
                  subtitle: '${todayFiadoSales.length} venda(s)',
                  onTap: () => widget.onNavigate(3),
                ),
              ],
            ),
          if (_isVisible(_TodaySection.summary)) const SizedBox(height: 16),
          if (_isVisible(_TodaySection.shortcuts)) ...[
            _QuickShortcutsPanel(
              shortcuts: shortcuts.activeShortcuts,
              onNavigate: widget.onNavigate,
            ),
            const SizedBox(height: 16),
          ],
          LayoutBuilder(
            builder: (context, constraints) {
              final compact = constraints.maxWidth < 920;

              final left = Column(
                children: [
                  if (_isVisible(_TodaySection.sales)) ...[
                    _SalesTodayPanel(
                      sales: todaySales,
                      total: todayRevenue,
                      onOpen: () => widget.onNavigate(4),
                    ),
                    const SizedBox(height: 16),
                  ],
                  if (_isVisible(_TodaySection.lowStock)) ...[
                    _LowStockPanel(
                      products: lowStockProducts,
                      onOpen: () => widget.onNavigate(2),
                    ),
                    const SizedBox(height: 16),
                  ],
                  if (_isVisible(_TodaySection.losses)) ...[
                    _LossesPanel(
                      todayLosses: todayLosses,
                      recentLosses: recentLosses,
                      onOpen: () => widget.onNavigate(2),
                    ),
                    const SizedBox(height: 16),
                  ],
                ],
              );

              final right = Column(
                children: [
                  if (_isVisible(_TodaySection.cash)) ...[
                    _CashTodayPanel(
                      sales: todaySales,
                      onOpen: () => widget.onNavigate(4),
                    ),
                    const SizedBox(height: 16),
                  ],
                  if (_isVisible(_TodaySection.suppliersOpen)) ...[
                    _SuppliersOpenPanel(
                      purchases: openSupplierPurchases,
                      total: openSupplierAmount,
                      onOpen: () => widget.onNavigate(6),
                    ),
                    const SizedBox(height: 16),
                  ],
                  if (_isVisible(_TodaySection.fiado)) ...[
                    _FiadoTodayPanel(
                      sales: todayFiadoSales,
                      total: todayFiadoTotal,
                      onOpen: () => widget.onNavigate(3),
                    ),
                    const SizedBox(height: 16),
                  ],
                ],
              );

              if (compact) {
                return Column(children: [left, right]);
              }

              return Row(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Expanded(child: left),
                  const SizedBox(width: 16),
                  Expanded(child: right),
                ],
              );
            },
          ),
          if (visibleSections.values.every((value) => !value))
            _EmptyToday(onCustomize: _openCustomizeDialog),
        ],
      ),
    );
  }

  bool _isVisible(_TodaySection section) {
    return visibleSections[section] ?? true;
  }

  Future<void> _loadPreferences() async {
    final prefs = await SharedPreferences.getInstance();
    final raw = prefs.getString(_storageKey);

    if (raw != null && raw.trim().isNotEmpty) {
      final decoded = jsonDecode(raw);

      if (decoded is Map) {
        for (final section in _TodaySection.values) {
          final value = decoded[section.name];

          if (value is bool) {
            visibleSections[section] = value;
          }
        }
      }
    }

    if (!mounted) return;

    setState(() => loaded = true);
  }

  Future<void> _savePreferences() async {
    final prefs = await SharedPreferences.getInstance();

    await prefs.setString(
      _storageKey,
      jsonEncode(
        visibleSections.map((key, value) => MapEntry(key.name, value)),
      ),
    );
  }

  Future<void> _openCustomizeDialog() async {
    final result = await showDialog<Map<_TodaySection, bool>>(
      context: context,
      builder: (_) => _CustomizeTodayDialog(visibleSections: visibleSections),
    );

    if (result == null) return;

    setState(() {
      visibleSections
        ..clear()
        ..addAll(result);
    });

    await _savePreferences();
  }
}

