class _CustomizeTodayDialog extends StatefulWidget {
  const _CustomizeTodayDialog({required this.visibleSections});

  final Map<_TodaySection, bool> visibleSections;

  @override
  State<_CustomizeTodayDialog> createState() => _CustomizeTodayDialogState();
}

class _CustomizeTodayDialogState extends State<_CustomizeTodayDialog> {
  late Map<_TodaySection, bool> temp;

  @override
  void initState() {
    super.initState();
    temp = Map<_TodaySection, bool>.from(widget.visibleSections);
  }

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: const Text('Personalizar tela Hoje'),
      content: SizedBox(
        width: 620,
        height: 520,
        child: ListView(
          children: _TodaySection.values.map((section) {
            return SwitchListTile(
              value: temp[section] ?? true,
              onChanged: (value) {
                setState(() => temp[section] = value);
              },
              secondary: Icon(section.icon, color: AppColors.wine700),
              title: Text(
                section.label,
                style: const TextStyle(fontWeight: FontWeight.w900),
              ),
              subtitle: Text(section.subtitle),
            );
          }).toList(),
        ),
      ),
      actions: [
        TextButton(
          onPressed: () {
            setState(() {
              temp = {
                for (final section in _TodaySection.values) section: true,
              };
            });
          },
          child: const Text('Ativar tudo'),
        ),
        TextButton(
          onPressed: () => Navigator.of(context).pop(),
          child: const Text('Cancelar'),
        ),
        FilledButton.icon(
          onPressed: () => Navigator.of(context).pop(temp),
          icon: const Icon(Icons.save_rounded),
          label: const Text('Salvar'),
        ),
      ],
    );
  }
}

IconData _shortcutIcon(DashboardShortcutType type) {
  switch (type) {
    case DashboardShortcutType.sale:
      return Icons.point_of_sale_rounded;
    case DashboardShortcutType.inventory:
      return Icons.inventory_2_rounded;
    case DashboardShortcutType.credit:
      return Icons.people_alt_rounded;
    case DashboardShortcutType.notes:
      return Icons.local_shipping_rounded;
    case DashboardShortcutType.cash:
      return Icons.payments_rounded;
    case DashboardShortcutType.reports:
      return Icons.bar_chart_rounded;
    case DashboardShortcutType.alerts:
      return Icons.notifications_rounded;
  }
}

bool _isToday(DateTime date) {
  final now = DateTime.now();

  return date.year == now.year &&
      date.month == now.month &&
      date.day == now.day;
}

Color _panelColor(BuildContext context) {
  return Theme.of(context).brightness == Brightness.dark
      ? AppColors.darkSurface
      : const Color(0xFFFBF6F0);
}

Color _miniCardColor(BuildContext context) {
  return Theme.of(context).brightness == Brightness.dark
      ? AppColors.darkSurfaceAlt
      : AppColors.white;
}

Color _borderColor(BuildContext context) {
  return AppColors.wine900.withOpacity(
    Theme.of(context).brightness == Brightness.dark ? 0.24 : 0.10,
  );
}

Color _titleColor(BuildContext context) {
  return Theme.of(context).brightness == Brightness.dark
      ? AppColors.beige100
      : AppColors.wine900;
}

Color _bodyColor(BuildContext context) {
  return Theme.of(context).brightness == Brightness.dark
      ? AppColors.beige100
      : const Color(0xFF2B1B1B);
}

Color _mutedColor(BuildContext context) {
  return Theme.of(context).brightness == Brightness.dark
      ? AppColors.beige100.withOpacity(0.68)
      : AppColors.wine900.withOpacity(0.62);
}

String _formatMoney(double value) {
  return NumberFormat.currency(locale: 'pt_BR', symbol: 'R\$').format(value);
}

String _formatDate(DateTime value) {
  return DateFormat('dd/MM').format(value);
}

String _formatTime(DateTime value) {
  return DateFormat('HH:mm').format(value);
}

String _formatDateTime(DateTime value) {
  return DateFormat('dd/MM HH:mm').format(value);
}

String _formatNumber(double value) {
  if (value == value.roundToDouble()) {
    return value.toStringAsFixed(0);
  }

  return value.toStringAsFixed(2).replaceAll('.', ',');
}
